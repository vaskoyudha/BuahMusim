# ─────────────────────────────────────────────────────────────────────────────
# BuahMusim — Environment Variables
# Copy this file to .env (for Docker) or apps/web/.env.local (for manual dev)
# ─────────────────────────────────────────────────────────────────────────────

# Groq API key for AI "Buy/Wait" recommendations (optional)
# Without this the app uses a deterministic template fallback — fully functional.
# Get a FREE key at https://console.groq.com  (free tier is sufficient)
GROQ_API_KEY=

# ML service base URL (optional)
# In Docker Compose this is automatically set to http://ml-service:8000
# For manual dev, start the FastAPI service on port 8000 first
ML_SERVICE_URL=http://localhost:8000

# SQLite database path (optional)
# In Docker this is inside a named volume for persistence across restarts.
# For manual dev the default relative path works fine.
DATABASE_PATH=./data/buahmusim.db
